{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
		"@dotpp/ai": ["./packages/ai/src/index.ts"],
		"@dotpp/ai/oauth": ["./packages/ai/src/oauth.ts"],
		"@dotpp/ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
		"@dotpp/ai/dist/*": ["./packages/ai/src/*"],
		"@dotpp/agent-core": ["./packages/agent/src/index.ts"],
		"@dotpp/agent-core/*": ["./packages/agent/src/*"],
		"@dotpp/coding-agent": ["./packages/coding-agent/src/index.ts"],
		"@dotpp/coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
		"@dotpp/coding-agent/*": ["./packages/coding-agent/src/*"],
		"typebox": ["./node_modules/typebox"],
		"@dotpp/tui": ["./packages/tui/src/index.ts"],
		"@dotpp/tui/*": ["./packages/tui/src/*"],
		"@dotpp/agent-old": ["./packages/agent-old/src/index.ts"],
		"@dotpp/agent-old/*": ["./packages/agent-old/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["**/dist/**", "packages/coding-agent/examples/extensions/gondolin/**"]
}
